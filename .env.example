# ==========================================================================
# GO — variáveis de ambiente (copie para .env e preencha). NÃO commite o .env.
# ==========================================================================

# Banco de dados MySQL
DATABASE_URL=mysql://user:pass@host:3306/goapp

# Sessão (assina o cookie JWT). Use uma string longa e aleatória.
JWT_SECRET=troque-por-uma-chave-aleatoria-bem-longa

# Identificador do app
VITE_APP_ID=go-app

# --- Web Push (gere com: npx web-push generate-vapid-keys) ---
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Mapas ---
# O app usa OpenStreetMap (Leaflet) no frontend e Nominatim no backend — SEM
# chave de API. Opcional: aponte para um Nominatim próprio/self-hosted.
# NOMINATIM_URL=https://nominatim.openstreetmap.org/reverse

# --- Alertas da central (opcional): webhook próprio (Slack/e-mail/seu sistema) ---
OWNER_WEBHOOK_URL=

# --- Lembretes de cobrança agendados (cron) ---
# Defina um segredo e agende GET /api/cron/billing-reminders?token=CRON_SECRET 1x/dia
CRON_SECRET=

# --- Ingestão do rastreador (Fase 3) ---
# Chave que a plataforma/hardware do rastreador usa para enviar telemetria real
INGEST_API_KEY=

# --- Integração GO360 (portal do cliente: login, equipamento, contrato, cobrança) ---
GO360_ENABLED=0   # 1 para usar o GO360 como autenticação/dados reais (0 = login local/demo)
GO360_BASE_URL=https://go360id-production.up.railway.app/api/app

# --- Canais extras p/ alertas críticos (opcionais; ativam quando preenchidos) ---
# E-mail diário do alerta crítico (Resend). Sem isso, só push + app.
RESEND_API_KEY=
EMAIL_FROM=GO <alertas@seudominio.com.br>
# SMS/WhatsApp (Twilio). Entrega comprovável para nível crítico (tem custo/msg).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=          # ex.: +5511999999999
TWILIO_WHATSAPP_FROM=     # ex.: +14155238886 (número WhatsApp do Twilio)
# Desliga o agendador interno (lembretes diários) se necessário
SCHEDULER_DISABLED=

# --- Render do modelo no card (estilo app de montadora) ---
# (Opcional) CDN de imagens de veículos (imagin.studio), usado no cliente.
VITE_CAR_IMAGE_KEY=
# (Opcional) Biblioteca própria que se auto-constrói via Google Programmable
# Search. Sem isto, a biblioteca usa só curadoria manual (sem custo/copyright).
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# --- App nativo (Capacitor): URL do backend de produção ---
VITE_API_URL=

# --- Storage S3 próprio (opcional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================================================
# Legado Manus (não preencher se estiver usando infra própria):
# OAUTH_SERVER_URL=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
# ==========================================================================

# Criptografia em repouso do token GO360 (qualquer string; vazio = desligado)
TOKEN_ENC_KEY=
