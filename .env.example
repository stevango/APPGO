# ==========================================================================
# GO — variáveis de ambiente (copie para .env e preencha). NÃO commite o .env.
# ==========================================================================

# Banco de dados MySQL
DATABASE_URL=mysql://user:pass@host:3306/goapp

# Sessão (assina o cookie JWT). Use uma string longa e aleatória.
JWT_SECRET=troque-por-uma-chave-aleatoria-bem-longa

# Identificador do app
VITE_APP_ID=go-app

# --- Web Push (gere com: npx web-push generate-vapid-keys) ---
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Google Maps (chaves próprias) ---
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=

# --- Alertas da central (opcional): webhook próprio (Slack/e-mail/seu sistema) ---
OWNER_WEBHOOK_URL=

# --- App nativo (Capacitor): URL do backend de produção ---
VITE_API_URL=

# --- Storage S3 próprio (opcional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================================================
# Legado Manus (não preencher se estiver usando infra própria):
# OAUTH_SERVER_URL=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
# ==========================================================================
